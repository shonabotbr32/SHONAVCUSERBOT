# Telegram API Credentials
# Get from: https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Session Name
SESSION_NAME=voice_boost_userbot

# Audio Settings
VOLUME_BOOST=10.0
SAMPLE_RATE=48000
CHANNELS=2

# FFmpeg Audio Filters
# Format: volume=X,highpass=f=Y,lowpass=f=Z,afftdn=nf=W
FFMPEG_FILTERS=volume=10.0,highpass=f=200,lowpass=f=3000,afftdn=nf

# Logging
LOG_LEVEL=INFO
